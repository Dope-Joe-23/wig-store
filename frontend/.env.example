# ============================================================
#  Wiggle Store — Frontend Environment Variables
#  Deploying: Vercel (frontend)
#  Copy this file to .env.local or set in Vercel Dashboard
# ============================================================

# ---------- API ----------
# Your Render backend URL (no trailing slash)
# Development: http://localhost:8000/api/v1
# Production:  https://your-app.onrender.com/api/v1
VITE_API_URL=https://your-app.onrender.com/api/v1

# ---------- Cloudinary ----------
# For direct frontend image uploads (optional — most uploads go through backend)
# Get this from your Cloudinary Dashboard → Account Details
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name

# ---------- Google OAuth ----------
# Must match the Google Cloud Console OAuth client ID you created
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ---------- Facebook OAuth ----------
# Must match the Facebook App ID from your Facebook Developer dashboard
VITE_FACEBOOK_APP_ID=your-facebook-app-id

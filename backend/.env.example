# ============================================================
#  Affordable Hair and More — Backend Environment Variables
#  Deploying: Render (backend) | Vercel (frontend)
#  Copy this file to .env and fill in your values
# ============================================================

# ---------- Django Core ----------
# Generate a strong secret key:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-production-secret-key-here

# Set to False in production
DEBUG=False

# Comma-separated list of allowed hosts (no spaces)
ALLOWED_HOSTS=your-app.onrender.com,wig-store-seven.vercel.app

# Admin panel — change this to a non-guessable path in production!
ADMIN_URL=portal

# ---------- Database (Render PostgreSQL) ----------
DB_ENGINE=django.db.backends.postgresql
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=your-db-host.render.com
DB_PORT=5432

# ---------- Redis & Celery ----------
REDIS_URL=redis://your-redis-host:6379/0
CELERY_BROKER_URL=redis://your-redis-host:6379/0
CELERY_RESULT_BACKEND=redis://your-redis-host:6379/0

# ---------- JWT ----------
JWT_SECRET_KEY=your-jwt-secret-key

# ---------- Cloudinary (media storage) ----------
# Sign up at cloudinary.com (free tier: 25GB storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ---------- Email (Choose one) ----------
# Option A: Console (dev only — prints to terminal)
#   EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Option B: SendGrid (recommended for production)
#   EMAIL_BACKEND=sendgrid_backend.SendgridBackend
#   SENDGRID_API_KEY=your-sendgrid-api-key
# Option C: SMTP (Gmail, etc.)
#   EMAIL_BACKEND=apps.users.email_backend.CertifiEmailBackend
#   EMAIL_HOST=smtp.gmail.com
#   EMAIL_PORT=587
#   EMAIL_USE_TLS=True
#   EMAIL_HOST_USER=your-email@gmail.com
#   EMAIL_HOST_PASSWORD=your-app-password

EMAIL_BACKEND=sendgrid_backend.SendgridBackend
EMAIL_FROM=noreply@affordablehairandmore.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_SANDBOX_MODE=False

# ---------- OAuth ----------
# Google — Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://your-app.onrender.com/api/v1/auth/google/callback/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook — Create app at https://developers.facebook.com
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# ---------- Paystack (payments) ----------
# Get keys from https://dashboard.paystack.com
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# ---------- Frontend URLs ----------
FRONTEND_BASE_URL=https://wig-store-seven.vercel.app
PAYSTACK_CALLBACK_URL=https://wig-store-seven.vercel.app/payment/success

# ---------- CORS ----------
# Comma-separated list of frontend origins allowed to call your API
CORS_ALLOWED_ORIGINS=https://wig-store-seven.vercel.app
